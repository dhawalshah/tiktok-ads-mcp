# ── TikTok Business OAuth ────────────────────────────────────────────────────
# Create an app at https://business-api.tiktok.com/portal/ and grab the
# App ID and Secret. Add the callback URL below to "Advertiser redirect URLs"
# in the app settings.
TIKTOK_APP_ID=
TIKTOK_SECRET=

# Where TikTok should redirect after the user signs in.
# Defaults to ${BASE_URL}/oauth/callback if unset.
# TIKTOK_REDIRECT_URI=http://localhost:8080/oauth/callback

# ── STDIO / single-user mode (optional) ──────────────────────────────────────
# If set, the local STDIO transport (tiktok-ads-mcp CLI) uses this as its
# access token. NOT used by the HTTP server, which gets per-user tokens
# via the OAuth flow.
# TIKTOK_ACCESS_TOKEN=
# TIKTOK_ADVERTISER_ID=

# ── Server identity (HTTP server / Cloud Run mode) ───────────────────────────
# Public URL where this service is reachable. Used for OAuth metadata
# (issuer, authorization_endpoint, token_endpoint) and the canonical
# resource URI MCP clients bind their tokens to.
# Local dev: http://localhost:8080
# Cloud Run: https://your-service-xxxx.run.app
BASE_URL=http://localhost:8080

# ── Firestore (token storage) ────────────────────────────────────────────────
# GCP project hosting the Firestore database. Required for HTTP server mode.
GCP_PROJECT_ID=

# ── Access control (optional) ────────────────────────────────────────────────
# Comma-separated list of TikTok-account emails permitted to authenticate.
# TikTok returns whatever email the user signed up with (often personal),
# so domain-based allowlisting isn't useful here.
# Empty/unset = anyone with a TikTok Business account may connect (but they
# only see ad accounts their TikTok profile has access to).
# Example: ALLOWED_EMAILS=alice@gmail.com,bob@hotmail.com
ALLOWED_EMAILS=

# ── API tuning ───────────────────────────────────────────────────────────────
# TIKTOK_SANDBOX=false
# TIKTOK_REQUEST_TIMEOUT=30
# PORT=8080
